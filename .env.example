# Crypto
COINGECKO_API_KEY=your_coingecko_api_key

# Email / Notifications
RESEND_API_KEY=your_resend_api_key

# Storage
STORAGE_BUCKET=auditor-app-documents

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars
